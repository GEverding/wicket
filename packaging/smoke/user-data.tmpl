#cloud-config
users:
  - name: tester
    shell: /bin/bash
    lock_passwd: true
    sudo: ALL=(ALL) NOPASSWD:ALL
    ssh_authorized_keys:
      - __SSH_PUBKEY__

ssh_pwauth: false
package_update: true
packages:
  - curl
  - python3

runcmd:
  - [sh, -c, 'echo cloud-init-done > /tmp/cloud-init-done']
