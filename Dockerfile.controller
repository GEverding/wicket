# Wicket Gateway API Controller Dockerfile
# Multi-stage build for minimal runtime image

# Stage 1: Build
FROM rust:1.85-slim-bookworm AS builder

RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    cmake \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# Copy manifests first for layer caching
COPY Cargo.toml Cargo.lock ./
COPY crates/wicket/Cargo.toml crates/wicket/
COPY crates/wicket-config/Cargo.toml crates/wicket-config/
COPY crates/wicket-controller/Cargo.toml crates/wicket-controller/
COPY crates/wicket-core/Cargo.toml crates/wicket-core/
COPY crates/wicket-sockmap/Cargo.toml crates/wicket-sockmap/
COPY crates/wicket-stream/Cargo.toml crates/wicket-stream/
COPY crates/wicket-tls/Cargo.toml crates/wicket-tls/

# Create dummy source files for dependency caching
RUN for dir in wicket wicket-config wicket-controller wicket-core wicket-sockmap wicket-stream wicket-tls; do \
        mkdir -p "crates/${dir}/src" && \
        echo "fn main() {}" > "crates/${dir}/src/main.rs" && \
        echo "pub fn _dummy() {}" > "crates/${dir}/src/lib.rs"; \
    done

# Build dependencies only (cached layer)
RUN cargo build --release --package wicket-controller 2>/dev/null || true

# Copy actual source code
COPY crates crates

# Touch source files to ensure rebuild
RUN find crates -name "*.rs" -exec touch {} +

# Build the controller binary
RUN cargo build --release --package wicket-controller

# Stage 2: Runtime
FROM debian:bookworm-slim

# Install runtime dependencies
RUN apt-get update && apt-get install -y \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN groupadd -g 65532 wicket && \
    useradd -u 65532 -g wicket -s /sbin/nologin wicket

# Create directories for TLS certificates and config
RUN mkdir -p /etc/wicket /var/run/wicket/tls && \
    chown -R wicket:wicket /etc/wicket /var/run/wicket

# Copy binary from builder
COPY --from=builder /build/target/release/wicket-controller /usr/local/bin/wicket-controller

# Use non-root user
USER wicket

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD wget -q --spider http://localhost:8081/healthz || exit 1

# Default command
ENTRYPOINT ["/usr/local/bin/wicket-controller"]

# Expose metrics port
EXPOSE 8081

# Labels
LABEL org.opencontainers.image.title="Wicket Gateway API Controller"
LABEL org.opencontainers.image.description="Kubernetes Gateway API controller for Wicket"
LABEL org.opencontainers.image.source="https://github.com/geverding/wicket"
