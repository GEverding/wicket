{
  "annotations": { "list": [] },
  "description": "Wicket Kubernetes controller health and reconciliation metrics",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    { "title": "Reconciliation Rate", "type": "timeseries", "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }, "targets": [ { "expr": "sum by (resource_type) (rate(wicket_reconcile_total{job=~\"$job\",instance=~\"$instance\"}[5m]))", "legendFormat": "{{ resource_type }}" }, { "expr": "sum by (instance, resource_type) (rate(wicket_reconcile_total{job=~\"$job\",instance=~\"$instance\"}[5m]))", "legendFormat": "{{ instance }} {{ resource_type }}" } ] },
    { "title": "Reconciliation Error Rate", "type": "timeseries", "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }, "targets": [ { "expr": "sum by (resource_type) (rate(wicket_reconcile_total{job=~\"$job\",instance=~\"$instance\",result=\"error\"}[5m])) / sum by (resource_type) (rate(wicket_reconcile_total{job=~\"$job\",instance=~\"$instance\"}[5m]))", "legendFormat": "{{ resource_type }}" } ] },
    { "title": "Reconciliation Duration p99", "type": "timeseries", "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }, "targets": [ { "expr": "histogram_quantile(0.99, sum by (le, resource_type) (rate(wicket_reconcile_duration_seconds_bucket{job=~\"$job\",instance=~\"$instance\"}[5m])))", "legendFormat": "{{ resource_type }}" }, { "expr": "histogram_quantile(0.99, sum by (le, instance, resource_type) (rate(wicket_reconcile_duration_seconds_bucket{job=~\"$job\",instance=~\"$instance\"}[5m])))", "legendFormat": "{{ instance }} {{ resource_type }}" } ] },
    { "title": "Leader Status", "type": "stat", "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "targets": [ { "expr": "max by (instance) (wicket_controller_is_leader{job=~\"$job\",instance=~\"$instance\"})", "legendFormat": "{{ instance }}" } ] },
    { "title": "Config Sync Lag", "type": "stat", "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "unit": "s" } }, "targets": [ { "expr": "max by (instance) (wicket_config_sync_lag_seconds{job=~\"$job\",instance=~\"$instance\"})", "legendFormat": "{{ instance }}" } ] },
    { "title": "Queue Depth", "type": "stat", "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "targets": [ { "expr": "sum by (resource_type) (wicket_reconcile_queue_depth{job=~\"$job\",instance=~\"$instance\"})", "legendFormat": "{{ resource_type }}" } ] },
    { "title": "Uptime", "type": "stat", "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "unit": "s" } }, "targets": [ { "expr": "max by (instance) (wicket_controller_uptime_seconds{job=~\"$job\",instance=~\"$instance\"})", "legendFormat": "{{ instance }}" } ] },
    { "title": "Gateway API Resource Counts", "type": "timeseries", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } } }, "targets": [ { "expr": "sum(wicket_gateway_classes{job=~\"$job\",instance=~\"$instance\"})", "legendFormat": "GatewayClasses" }, { "expr": "sum(wicket_gateways{job=~\"$job\",instance=~\"$instance\"})", "legendFormat": "Gateways" }, { "expr": "sum(wicket_httproutes{job=~\"$job\",instance=~\"$instance\"})", "legendFormat": "HTTPRoutes" }, { "expr": "sum(wicket_tcproutes{job=~\"$job\",instance=~\"$instance\"})", "legendFormat": "TCPRoutes" }, { "expr": "sum(wicket_tlsroutes{job=~\"$job\",instance=~\"$instance\"})", "legendFormat": "TLSRoutes" } ] },
    { "title": "Backend Endpoint Health", "type": "timeseries", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } } }, "targets": [ { "expr": "sum by (service) (wicket_backend_endpoints_healthy{job=~\"$job\",instance=~\"$instance\"})", "legendFormat": "{{ service }} healthy" }, { "expr": "sum by (service) (wicket_backend_endpoints_unhealthy{job=~\"$job\",instance=~\"$instance\"})", "legendFormat": "{{ service }} unhealthy" } ] },
    { "title": "K8s API Duration p99", "type": "timeseries", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }, "targets": [ { "expr": "histogram_quantile(0.99, sum by (le, operation) (rate(wicket_k8s_api_duration_seconds_bucket{job=~\"$job\",instance=~\"$instance\"}[5m])))", "legendFormat": "{{ operation }}" } ] },
    { "title": "K8s API and Watch Errors", "type": "timeseries", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "bars", "fillOpacity": 50 } } }, "targets": [ { "expr": "sum by (operation, error_type) (rate(wicket_k8s_api_errors_total{job=~\"$job\",instance=~\"$instance\"}[5m]))", "legendFormat": "api {{ operation }} {{ error_type }}" }, { "expr": "sum by (resource_type) (rate(wicket_watch_errors_total{job=~\"$job\",instance=~\"$instance\"}[5m]))", "legendFormat": "watch {{ resource_type }}" } ] }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["wicket", "controller", "kubernetes"],
  "templating": { "list": [
    { "name": "datasource", "label": "Prometheus", "type": "datasource", "query": "prometheus", "current": { "text": "Prometheus", "value": "Prometheus" } },
    { "name": "job", "label": "Prometheus job", "type": "query", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "query": "label_values(wicket_reconcile_total, job)", "refresh": 1, "includeAll": true, "allValue": ".*", "multi": true },
    { "name": "instance", "label": "Controller instance", "type": "query", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "query": "label_values(wicket_reconcile_total{job=~\"$job\"}, instance)", "refresh": 1, "includeAll": true, "allValue": ".*", "multi": true }
  ] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Wicket Controller - Fleet",
  "uid": "wicket-controller-fleet",
  "version": 1,
  "weekStart": ""
}
